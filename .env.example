# Copy this file to .env and fill in. Loaded by docker-compose and the
# Makefile; *not* loaded by the Python code (use ~/.memex/*.yaml for
# that).

# === Storage / Memory ===
# Hindsight daemon endpoint. Default localhost; override if you run the
# daemon on a different host (e.g. NAS, separate dev box, Tailscale).
MEMEX_HINDSIGHT_URL=http://127.0.0.1:8888
MEMEX_HINDSIGHT_FALLBACK_URL=
MEMEX_HINDSIGHT_BANK=memory_full_v5
MEMEX_HINDSIGHT_TIMEOUT=180.0

# === Workspace ===
# Where Memgraph stores its working directory (logs, runtime state, etc.)
# Default: ~/.claude/projects
MEMEX_WORKSPACE_ROOT=

# === Extraction LLM ===
# OpenAI-compatible endpoint. Works with vLLM, Ollama, OneAPI, LiteLLM
# proxy, or any commercial provider that ships a chat-completions API.
MEMEX_REMOTE_LLM_BASE_URL=
MEMEX_REMOTE_LLM_API_KEY=
MEMEX_REMOTE_LLM_GATE_MODEL=
MEMEX_REMOTE_LLM_EXTRACT_MODEL=

# === Per-user identifiers ===
# Optional: only set if you ingest QQ history. Path to QQ desktop DB will
# be derived from this id.
MEMEX_QQ_ID=
MEMEX_PRIMARY_EMAIL=

# === Alias config file location ===
# Optional override; default ~/.memex/aliases.yaml
MEMEX_ALIASES_FILE=
